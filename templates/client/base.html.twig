<!DOCTYPE html>
<html>
   <head>
        <meta charset="UTF-8">
        <title>{% block title %}Proprietaire{% endblock %}</title>
        <link href="https://fonts.googleapis.com/css?family=Rubik:400,700|Crimson+Text:400,400i" rel="stylesheet">
        <link rel="stylesheet" href="{{ asset('fonts/icomoon/style.css') }}">
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

        <link rel="stylesheet" href="{{ asset('css/bootstrap.min.css') }}">
        <link rel="stylesheet" href="{{ asset('css/magnific-popup.css') }}">
        <link rel="stylesheet" href="{{ asset('css/jquery-ui.css') }}">
        <link rel="stylesheet" href="{{ asset('css/owl.carousel.min.css') }}">
        <link rel="stylesheet" href="{{ asset('css/owl.theme.default.min.css') }}">


        <link rel="stylesheet" href="{{ asset('css/aos.css') }}">

        <link rel="stylesheet" href="{{ asset('css/style.css') }}">
        
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
    <div class="site-wrap">
        {% block header %}
            <div class="site-navbar py-2">

                <div class="search-wrap">
                    <div class="container">
                    <a href="#" class="search-close js-search-close"><span class="icon-close2"></span></a>
                    <form action="#" method="post">
                        <input type="text" class="form-control" placeholder="Search keyword and hit enter...">
                    </form>
                    </div>
                </div>

                <div class="container">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="logo">
                            <div class="site-logo">

                          
                            <a href="{{ path('home') }}" class="js-logo-clone">MaPharmacie</a>

                            </div>
                        </div>
                        <div class="main-nav d-none d-lg-block">
                            <nav class="site-navigation text-right text-md-center" role="navigation">
                            <ul class="site-menu js-clone-nav d-none d-lg-block">
                                <li class="{{ app.request.get('_route') == 'home' ? 'active' }}"><a href="{{ path('home') }}" class="hyper">Acceuil</a></li>
                                <li class="{{ app.request.get('_route') == 'shop' ? 'active' }}"><a href="{{ path('shop') }}"class="hyper">Marquet</a></li>
                                {% if categories|default(null) %}
                                <li class="has-children">
                                
                                <a href="#" class="hyper">Catégorie</a>
                                <ul class="dropdown">
                          {% for categorie in categories %}
                                
                                    <li><a href="#">{{categorie.nom}}</a></li> 
                              
                            {% endfor %}
                                </ul>

                  
                                </li>
                                {% endif %}
                                <li><a href="{{ path('about') }}" class="hyper">About</a></li>
                                <li><a href="{{ path('contact') }}" class="hyper">Contact</a></li>
                            </ul>
                            </nav>
                        </div>
                        <div class="icons">
                            {% if not app.user %}
                            <a href="{{ path('inscription') }}">Inscription</a>
                            {% endif %}
                            <a href="#" class="icons-btn d-inline-block js-search-open"><span class="icon-search"></span></a>
                            <a href="{{path('cart')}}" class="icons-btn d-inline-block bag" id="my-cart">
                            <span class="icon-shopping-bag"></span>
                            <span class="number">0</span>
                            </a>
                            <a href="#" class="site-menu-toggle js-menu-toggle ml-3 d-inline-block d-lg-none"><span
                                class="icon-menu"></span></a>
                            {% if not app.user %}    
                            <script> const idd="guest"; </script>
                            <a href="{{ path('app_login') }}">Connexion</a>
                            {% else %}
                            <script> const idd="{{app.user.id}}" ;
                             if(JSON.parse(localStorage.getItem("my_cart_infos")).filter(x=>x.id=="guest").length)
                             {      let strg=JSON.parse(localStorage.getItem("my_cart_infos"));
                                    if(!JSON.parse(localStorage.getItem("my_cart_infos")).filter(x=>x.id=idd).length)
                                       {
                                          console.log( strg.filter(x=>x.id=="guest"));
                                        let crt={id:idd,items:strg.filter(x=>x.id=="guest")[0].items};
                                         
                                           strg.push(crt);
                                           console.log(strg.map(x=>x.id).indexOf("guest"));
                                         
                                         
                                          
                                       }  
                                    else{
                                       let arr1=strg.filter(x=>x.id=="guest")[0].items;
                                       let arr2=strg.filter(x=>x.id==idd)[0].items;
                                       let ar=(arr1.length>arr2.length)?arr1:arr2;
                                       let av=(ar==arr1)?arr2:arr1;
                                       let av_id=av.map(x=>x.id);
                                       for(i in ar)
                                       {
                                         if(av_id.indexOf(ar[i].id)!==-1)
                                         {
                                           ar[i].qt+= av[av_id.indexOf(ar[i].id)].qt;
                                         }

                                       }
                                       
                                       strg.splice(strg.map(x=>x.id).indexOf(idd),1);
                                       strg.push({id:idd,items:ar});

                                       console.log(ar);
                                      
                                   
                                    }
                                    strg.splice(strg.map(x=>x.id).indexOf("guest"),1);
                                    localStorage.setItem("my_cart_infos",JSON.stringify(strg));

                             }

                            
                            
                            </script>
                              <b> {{app.user.nom}} </b> <a href="{{ path('app_logout') }}"> Déconnexion </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            {% block nav %}
            <div class="bg-light py-3">
              <div class="container">
                <div class="row">
                  <div class="col-md-12 mb-0">
                    <a href="{{ path('home_proprietaire') }}">Home</a> <span class="mx-2 mb-0">/</span>
                    <strong class="text-black">{{pagetitle}}</strong>
                  </div>
                </div>
              </div>
            </div>
            {% endblock %}
        {% endblock %}
        {% block body %}{% endblock %}
        {% block footer %}
            <footer class="site-footer">
              <div class="container">
                <div class="row">
                  <div class="col-md-6 col-lg-3 mb-4 mb-lg-0">

                    <div class="block-7">
                      <h3 class="footer-heading mb-4">About Us</h3>
                      <p>Lorem ipsum dolor sit amet, consectetur adipisicing elit. Eius quae reiciendis distinctio voluptates
                        sed dolorum excepturi iure eaque, aut unde.</p>
                        <u> <a href="{{ path('about') }}" class="text-primary">Nous connaitre mieux</a></u>

                    </div>

                  </div>
                  <div class="col-lg-3 mx-auto mb-5 mb-lg-0">
                    <h3 class="footer-heading mb-4">Quick Links</h3>
                    <ul class="list-unstyled">
                      <li><a href="#">Supplements</a></li>
                      <li><a href="#">Vitamins</a></li>
                      <li><a href="#">Diet &amp; Nutrition</a></li>
                      <li><a href="#">Tea &amp; Coffee</a></li>
                    </ul>
                    <u> <a href="{{ path('shop') }}" class="text-primary">Voir plus dans le marquet</a></u>
                  </div>

                  <div class="col-md-6 col-lg-3">
                    <div class="block-5 mb-5">
                      <h3 class="footer-heading mb-4">Contact Info</h3>
                      <ul class="list-unstyled">
                        <li class="address">203 Fake St. Mountain View, San Francisco, California, USA</li>
                        <li class="phone"><a href="tel://23923929210">+2 392 3929 210</a></li>
                        <li class="email">emailaddress@domain.com</li>
                      </ul>
                      <u> <a href="{{ path('contact') }}" class="text-primary">Dites nous ce que vous pensez !
                    </div>


                  </div>
                </div>
                <div class="row pt-5 mt-5 text-center">
                  <div class="col-md-12">
                    <p>
                      <!-- Link back to Colorlib can't be removed. Template is licensed under CC BY 3.0. -->
                      Copyright &copy;
                      <script>document.write(new Date().getFullYear());</script> All rights reserved | This template is made
                      with <i class="icon-heart" aria-hidden="true"></i> by <a href="{{path('about')}}" target="_blank"
                        class="text-primary">WASIM</a>
                      <!-- Link back to Colorlib can't be removed. Template is licensed under CC BY 3.0. -->
                    </p>
                  </div>

                </div>
              </div>
            </footer>
        {% endblock %}
    </div>
        {% block javascripts %}
            <script>
            
                console.log(idd);
             let storage=localStorage.getItem("my_cart_infos");
             let cart=document.getElementById("my-cart");
if(!storage) {cart.childNodes[3].innerHTML=0;}
else { 
  

       if( JSON.parse(storage).map( x=> x.id).includes(idd )  )
    {cart.childNodes[3].innerHTML=JSON.parse(storage).filter( x=>x.id==idd).map(y=>y.items)[0].reduce(function(acc,v){return {qt:acc.qt*1 +v.qt*1}}).qt; }
	
	 else cart.childNodes[3].innerHTML=0;
}
	   
	   
            
            </script>
                  <script src="{{ asset('js/jquery-3.3.1.min.js') }}"></script>
                  <script src="{{ asset('js/jquery-ui.js') }}"></script>
                  <script src="{{ asset('js/popper.min.js') }}"></script>
                  <script src="{{ asset('js/bootstrap.min.js') }}"></script>
                  <script src="{{ asset('js/owl.carousel.min.js') }}"></script>
              
      

            
        {% endblock %}
    </body>
</html>
