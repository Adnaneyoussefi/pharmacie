
{% extends 'admin/base.html.twig' %}
{% block body %}

    <div class="site-section">
      <div class="container">
       <form method="POST">
          <div class="row mb-4">
            <div class="form-group col-md-9">
              <input id="exampleFormControlInput5" name="email"  placeholder="What're you searching for?"  class="form-control form-control-underlined" required >
            </div>
            <div class="form-group col-md-3">
              <button type="submit" class="btn btn-primary rounded-pill btn-block shadow-sm">Search</button>
            </div>
          </div>
        </form>
        <div class="row mb-5">
          <form class="col-md-12" method="post">
            <div class="site-blocks-table">
              <table class="table table-bordered">
                <thead>
                  <tr>
                    <th class="product-name">Pharmacie</th>
                    <th class="product-name">Nom du propriétaire</th>
                    <th class="product-name">Prénom du propriétaire</th>
                    <th class="product-adresse">Email</th>
                    <th class="product-telephone">Adresse</th>
                    <th class="product-telephone">Ville</th>
                    <th class="product-remove">Supprimer</th>
                  </tr>
                </thead>
                <tbody>

                {% for user in page %}
                  <tr>
                    
                    <td class="product-name">
                      <h2 class="h5 text-black"> {{user.proprietaire.nomPharmacie}}</h2>
                    </td>
                    <td class="product-name">
                      <h2 class="h5 text-black">{{user.nom}}</h2>
                    </td>
                    <td class="product-name">
                      <h2 class="h5 text-black">{{user.prenom}}</h2>
                    </td>
                    <td>{{user.email}}</td>
                    
                    <td>{{user.proprietaire.adresse}}</td>

                    <td>{{user.proprietaire.ville}}</td>

                    <td><a href="{{ path('listpharmacie_admin_remove',{'id':user.id})}}" class="btn btn-primary height-auto btn-sm">X</a></td>
                </tr>
                {% endfor %}
                
                </tbody>
              </table>
            </div>
             <div class:"navigation">
              {{ knp_pagination_render(page)}}
              </div>
          </form>
        </div>
    

{% endblock %}
