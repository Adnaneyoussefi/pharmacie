{% extends'admin/base.html.twig'%}

{% block body %}


<script src="https://cdn.jsdelivr.net/npm/chart.js@2.8.0"></script>

 <div class="site-section">
      <div class="container">
        <div style="width :75%"> 
          <style>
            #line-chart{
            position: relative;
            top: -80px;
            }
                        </style>
         <canvas id="line-chart" width="800" height="450"></canvas>
          </div>
          <script>
         new Chart(document.getElementById("line-chart"), {
  type: 'line',
  data: {
    labels: ["Janvier","Fevrier","Mars","Avril","Mai","Juin","Juillet","Aout","Septembre","Octobre","Novembre","Decembre"],
    datasets: [{ 
        data: [86,114,106,106,107,111,133,221,783,2478,123,3756],
        label: "Parapharmacie",
        borderColor: "lime",
        fill: false
      }, { 
        data: [1000,350,411,502,635,809,947,1402,3700,5267,1230,1593],
        label: "Client",
        borderColor: "aqua",
        fill: false
      },
    ]
  },
  options: {
    title: {
      display: true,
      text: 'Nombre des inscriptions (Par mois)'
    }
  }
});
          
          </script>
    
{% endblock %}