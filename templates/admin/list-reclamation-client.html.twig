{% extends 'admin/base.html.twig' %}

{% block body %}
<br>
<center><h2> Reclamations </h2></center>
<br>
{% for reclamation in page %}
<div class="card">
  <div class="card-header">
    <h4>Titre du reclamation : {{reclamation.sujet}}</h4>
  </div>
  <div class="card-body">
    <blockquote class="blockquote mb-0">
      <p>Message : {{reclamation.message}}</p>
      <footer class="blockquote-footer">Emetteur : {{reclamation.user.nom}} {{reclamation.user.prenom}} </footer>
      <footer class="blockquote-footer">Email : {{reclamation.user.email}} </footer>


    </blockquote>
  </div> 
</div>
<div class:"navigation">
              {{ knp_pagination_render(page)}}
</div>
{% endfor %}



{% endblock %}