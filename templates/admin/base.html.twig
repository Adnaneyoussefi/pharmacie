<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Admin{% endblock %}</title>
        <link href="https://fonts.googleapis.com/css?family=Rubik:400,700|Crimson+Text:400,400i" rel="stylesheet">
        <link rel="stylesheet" href="../fonts/icomoon/style.css">

        <link rel="stylesheet" href="../css/bootstrap.min.css">
        <link rel="stylesheet" href="../css/magnific-popup.css">
        <link rel="stylesheet" href="../css/jquery-ui.css">
        <link rel="stylesheet" href="../css/owl.carousel.min.css">
        <link rel="stylesheet" href="../css/owl.theme.default.min.css">


        <link rel="stylesheet" href="../css/aos.css">

        <link rel="stylesheet" href="../css/style.css">
        
        {% block stylesheets %}{% endblock %}
        </head>
        <body>
          <div class="site-wrap">
  <div class="site-navbar py-2">

      <div class="container">
        <div class="d-flex align-items-center justify-content-between">
          <div class="logo">
            <div class="site-logo">
              <a href="{{path('home_admin')}}" class="js-logo-clone">PharmaClic</a>
            </div>
          </div>
          
          <div class="main-nav d-none d-lg-block">
            <nav class="site-navigation text-right text-md-center" role="navigation">
              <ul class="site-menu js-clone-nav d-none d-lg-block">
                <li><a href="{{path('home_admin')}}">Home</a></li>       
                <li><a href="{{path('listpharmacie_admin')}}">tableau pharmacie</a></li>       
                <li><a href="{{path('listclient_admin')}}">tableau client</a></li>       
                <li class="has-children">
                  <a>{{app.user.nom}} </a>
                  <ul class="dropdown">
                    <li><a href="{{path('parametres_admin')}}">Paramétres</a></li>
                    <li><a href="{{ path ('app_logout')}}">Déconnexion</a></li>

                  
                  </ul>
                </li>
               
              </ul>
            </nav>
          </div>
          </div>
        </div>
      </div>
      </div>
    <div class="bg-light py-3">
        <div class="container">
          <div class="row">
            <div class="col-md-12 mb-0">
              <a href="index.html">Home</a> <span class="mx-2 mb-0">/</span>
              <strong class="text-black">{{ pagetitle}}</strong>
            </div>
          </div>
        </div>
      </div>
    

    {% block body %} {% endblock %}
         <script src="../js/jquery-3.3.1.min.js"></script>
            <script src="../js/jquery-ui.js"></script>
            <script src="../js/popper.min.js"></script>
            <script src="../js/bootstrap.min.js"></script>
            <script src="../js/owl.carousel.min.js"></script>
            <script src="../js/jquery.magnific-popup.min.js"></script>
            <script src="../js/aos.js"></script>
            <script src="../js/main.js"></script>

    {% block javascripts %}
      {% endblock %}
  
       </body>
       </html>