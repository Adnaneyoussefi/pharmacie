{% extends 'proprietaire/base.html.twig' %}
{% block nav %}{% endblock %}
{% block body %}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@2.8.0"></script>
    <link rel="stylesheet" href="https://www.w3schools.com/w3css/4/w3.css">
       <div class="site-section">
            <div class="container">
            <div style="width :65%">
                  <canvas id="bar-chart" width="800" height="450"></canvas>       
            </div>
            </div>
            <div style="width :25%;  position: absolute; left: 70%; line-height: 150%; top:200px;">
                <div class="w3-light-grey">
                      <p>Visite</p>
                          <div class="w3-container w3-green w3-center" style="width:25%">25%</div>
                        </div><br>
                        <div class="w3-light-grey">
                      <p>Vente</p>
                          <div class="w3-container w3-red w3-center" style="width:50%">50%</div>
                        </div><br>
                        <div class="w3-light-grey">
                      <p>Vente</p>
                          <div class="w3-container w3-blue" style="width:75%">75%</div>
                        </div><br>
               </div>
            </div>
                  </div>
          <script>
          new Chart(document.getElementById("bar-chart"), {
              type: 'bar',
              data: {
                labels: ["Janvier", "Fevrier", "Mars", "Avril", "Juin","Juillet","Aout","Septembre","Octobre","Novembre","Decembre"],
                datasets: [
                  {
                    label: "commande",
                    backgroundColor: ["#3e95cd", "#8e5ea2","#3cba9f","#e8c3b9","#c45850","#FF7F50","#FF00FF","#DB7093","#40E0D0","#FFFF00","#BDB76B"],
                    data: [2478,5267,734,784,433,230,552,452,157,369,796]
                  }
                ]
              },
              options: {
                legend: { display: false },
                title: {
                  display: true,
                  text: 'Nombre des commandes par mois'
                }
              }
          });
          </script>
{% endblock %}