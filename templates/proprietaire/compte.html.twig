{% extends 'proprietaire/base.html.twig' %}
{% block body %}
<div class="site-section">
      <div class="container">
{% for message in app.flashes('notice') %}
              <div class="flash-notice">
                 {{ message }}
              </div>
              {% endfor %}
        <ul class="nav nav-tabs">
            <li class="nav-item">
              <a class="nav-link active" data-toggle="tab" href="#info">Information Personnelles</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" data-toggle="tab" href="#pwd">Changer le mot de passe</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-toggle="tab" href="#pharmacie">Information de pharmacie</a>
              </li>
          </ul>
          <div id="myTabContent" class="tab-content">
            <div class="tab-pane fade active show" id="info">
              {{ form_start(formInfoPerso) }}
              {{form_row(formInfoPerso.nom, {'label' : 'Nom', 'attr' : {'value' : app.user.nom}})}}
              {{ form_row(formInfoPerso.prenom, {'label' : 'Prenom', 'attr' : {'value' : app.user.prenom}}) }}

              {{ form_end(formInfoPerso) }}
            </div>
            <div class="tab-pane fade" id="pwd">
              
              {{ form_start(formPassword) }}
              
              {{ form_row(formPassword.oldpassword, {'label' : 'Le mot de passe actuel', 'attr' : {'placeholder' : "Ecrire l'ancien mot de passe"}}) }}
              
              {{ form_end(formPassword) }}
            </div>


            <div class="tab-pane fade" id="pharmacie">
              {{ form_start(formInfoPharma)}}
              {{ form_row(formInfoPharma.nom_pharmacie, {'label' : 'Nom de pharmacie', 'attr' : {'value' : app.user.proprietaire.nomPharmacie}}) }}
              {{ form_row(formInfoPharma.adresse_pharmacie, {'label' : 'Adresse', 'attr' : {'value' : app.user.proprietaire.adresse}}) }}
              {{ form_row(formInfoPharma.ville, {'label' : 'Ville', 'attr' : {'value' : app.user.proprietaire.ville}}) }}
              {{ form_end(formInfoPharma)}}
              

              </div>
          </div>
            
      </div>
    </div>
{% endblock %}