{% extends 'proprietaire/base.html.twig' %}
{% block body %}
<div class="site-section">
      <div class="container">

        <ul class="nav nav-tabs">
            <li class="nav-item">
              <a class="nav-link {{ active_tab1 }}" data-toggle="tab" href="#liste">Liste des produits</a>
            </li>
            <li class="nav-item">
              <a class="nav-link {{ active_tab2 }}" data-toggle="tab" href="#ajout">Ajouter des produits</a>
            </li>
          </ul>
          <div id="myTabContent" class="tab-content">
            
            <div class="tab-pane fade {{ active_tab1 }}" id="liste">
                <table class="table table-striped">
                    <thead>
                      <tr>
                        <th>Id</th>
                        <th>Image</th>
                        <th>Nom</th>
                        <th>Description</th>
                        <th>PRIX_HT</th>
                        <th>PRIX_TVA</th>
                        <th>Quantité</th>
                        <th>Date d'expiration</th>
                        <th>Action</th>
                      </tr>
                    </thead>
                    <tbody>
                    {% for stock in stocks|reverse %}
                        <tr>
                            <th>{{ stock.produit.id }}</th>
                            <td>
                            <img src={{ asset('images/' ~ stock.produit.image) }} alt="Image" style="width: 120px;">                              
                              </td>
                            <td>{{ stock.produit.nom }}</td>
                            <td>{{ stock.produit.description }}</td>
                            <td>{{ stock.produit.PrixHt }}</td>
                            <td>{{ stock.produit.PrixTva }}</td>
                            <td>{{ stock.quantite }}</td>
                            <td>{{ stock.produit.DateExpiration | date('d/m/Y') }}</td>
                            <td>
                                
                                <a href="{{ path('produit_show', {'id': stock.produit.id}) }}" class="btn btn-primary btn-sm d-block mb-1" style="width: 100px">Afficher</a>
                                <a href="{{ path('produit_edit', {'id': stock.produit.id}) }}" class="btn btn-warning btn-sm d-block mb-1" style="width: 100px">Modifier</a>
                                {{ include('proprietaire/_delete_form.html.twig') }}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                    </table>   
            </div>

            <div class="tab-pane fade {{ active_tab2 }}" id="ajout">
              
                {{ include('proprietaire/_form.html.twig') }}

            </div>
            
            
      </div>
    </div>
{% endblock %}