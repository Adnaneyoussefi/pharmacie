{% extends 'proprietaire/base.html.twig' %}
{% block body %}
<div class="site-section">
      <div class="container">

        <ul class="nav nav-tabs">
            <li class="nav-item">
              <a class="nav-link active" data-toggle="tab" href="#liste">Liste des produits</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" data-toggle="tab" href="#ajout">Ajouter des produits</a>
            </li>
          </ul>
          <div id="myTabContent" class="tab-content">
            
            <div class="tab-pane fade active show" id="liste">
                <table class="table table-hover">
                    <thead>
                      <tr>
                        <th scope="col">Id</th>
                        <th scope="col">Image</th>
                        <th scope="col">Nom</th>
                        <th scope="col">Description</th>
                        <th scope="col">PRIX_HT</th>
                        <th scope="col">PRIX_TVA</th>
                        <th scope="col">Quantité</th>
                        <th scope="col">Date d'expiration</th>
                        <th scope="col">Modifier-Supprimer</th>
                      </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <th scope="row">1</th>
                            <td>
                                <img src="../images/product_01.png" alt="Image" class="img-fluid">
                              </td>
                            <td>Produit 1</td>
                            <td>Lorem ipsum dolor sit amet consectetur adipisicing elit. Sapiente iusto impedit nam possimus, suscipit rerum voluptates debitis, omnis iure quam earum eum beatae incidunt numquam quaerat adipisci repudiandae mollitia tempora?</td>
                            <td>50$</td>
                            <td>10$</td>
                            <td>9</td>
                            <td>15/06/2020</td>
                            <td>
                                <button type="button" class="btn btn-warning btn-sm">Modifier</button>
                                <button type="button" class="btn btn-danger btn-sm">Supprimer</button>
                            </td>
                        </tr>
                          <tr class="table-active">
                            <th scope="row">2</th>
                            <td class="product-thumbnail">
                                <img src="../images/product_02.png" alt="Image" class="img-fluid">
                              </td>
                            <td>Produit 2</td>
                            <td>Lorem ipsum dolor sit, amet consectetur adipisicing elit. Facilis maiores maxime nihil adipisci molestiae esse atque, suscipit incidunt aliquam est non, consequatur distinctio sequi ratione alias laudantium voluptas officiis sed.</td>
                            <td>50$</td>
                            <td>10$</td>
                            <td>5</td>
                            <td>15/06/2020</td>
                            <td>
                                <button type="button" class="btn btn-warning btn-sm">Modifier</button>
                                <button type="button" class="btn btn-danger btn-sm">Supprimer</button>
                            </td>  
                        </tr>  
                    </tbody>
                    </table>   
            </div>

            <div class="tab-pane fade" id="ajout">
              
                <form>

                    <div class="form-group">
                        <label for="nomproduit" class="text-black">Image</label>
                        <div class="custom-file">
                            <input type="file" class="custom-file-input" id="inputGroupFile02">
                            <label class="custom-file-label" for="inputGroupFile02">Choisir image</label>
                        </div>
                    </div>

                    <div class="form-group">
                      <label for="nomproduit" class="text-black">Nom Produit</label>
                      <input type="text" class="form-control" id="nomproduit">
                    </div>

                    <div class="form-group">
                        <label for="prix" class="text-black">Prix</label>
                        <input type="text" class="form-control" id="prix">
                    </div>

                    <div class="form-group">
                        <label for="exampleTextarea" class="text-black">Description</label>
                        <textarea class="form-control" id="exampleTextarea" rows="3"></textarea>
                    </div>

                    <div class="form-group">
                        <label for="categorie" class="text-black">Categorie</label>
                        <select class="form-control" id="categorie">
                          <option>Douleurs-Fièvre</option>
                          <option>Rhume, mal de gorge</option>
                        </select>
                      </div>
                    <div class="form-group">
                      <button type="button" class="btn btn-primary">Enregistrer</button>
                    </div>
                </form>    
             

              <div class="form-group">
                <label class="text-black">Ajouter plusieurs produit depuis un fichier excel</label>
                <div class="input-group mb-3">
                  <div class="custom-file">
                    <input type="file" class="custom-file-input" id="inputGroupFile02">
                    <label class="custom-file-label" for="inputGroupFile02">Choose file</label>
                  </div>
                </div>
              </div>

              <button type="button" class="btn btn-primary">Enregistrer</button>

            </div>
            <div class="tab-pane fade" id="pharmacie">

              <form>
                
                <div class="form-group">
                  <label for="nompharmacie" class="text-black">Nom pharmacie</label>
                  <input type="text" class="form-control" id="nompharmacie">
                </div>

                <div class="form-group">
                  <label for="adressepharmacie" class="text-black">Adresse pharmacie</label>
                  <input type="text" class="form-control" id="adressepharmacie">
                </div>
              </form>
              </div>
          </div>
            
      </div>
    </div>
{% endblock %}